    "FB": "tackles_p90_adj(25%) + int_p90_adj(25%) + crosses_p90(20%) + minutes_share(15%) + consistency(15%) [POSSESSION-ADJUSTED]",
    "GK": "save_pct(40%) + cs_pct(30%) + ga_p90_inv(10%) + minutes_share(10%) + consistency(10%)"
  },
